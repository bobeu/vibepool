{
  "name": "smartcontracts",
  "license": "MIT",
  "version": "1.0.0",
  "scripts": {
    "compile": "bun x hardhat compile",
    "test": "bun x hardhat test",
    "deploy": "bun x hardhat deploy --network hardhat",
    "contract": "bun x hardhat compile && bun x hardhat test && bun x hardhat deploy --network hardhat",
    "deploy-testnet": "node sync-data.js && hardhat deploy --network sepolia --export deployments/contracts.json && node sync-data.js",
    "deploy-mainnet": "node sync-data.js && hardhat deploy --network celo --export deployments/contracts.json && node sync-data.js",
    "sync": "node sync-data.js",
    "tsc": "npx tsc -p . && cp typechain/*.d.ts dist/typechain/",
    "build": "yarn compile && yarn tsc",
    "clean": "hardhat clean",
    "forge:install": "rm -rf lib && forge install",
    "forge:build": "forge build",
    "forge:test": "forge test",
    "forge:coverage": "forge coverage"
  },
  "dependencies": {
    "@aave/core-v3": "^1.19.3",
    "@chainlink/contracts": "^1.5.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomiclabs/hardhat-web3": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@pythnetwork/pyth-sdk-solidity": "^4.3.1",
    "dotenv": "^17.2.1",
    "hardhat": "^2.22.17",
    "hardhat-deploy": "^0.12.4",
    "web3-utils": "^4.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.2.0",
    "@types/chai-as-promised": "^7.1.6",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "chai": "^4.2.0",
    "ethers": "^6.13.7",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.2",
    "typescript": "~5.0.4",
    "viem": "^2.52.2",
    "web3": "^1.0.0-beta.36",
    "forge-std": "https://github.com/foundry-rs/forge-std.git",
    "ds-test": "https://github.com/dapphub/ds-test.git"
  }
}
