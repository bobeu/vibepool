# ── Tester Scripts (tester/) ─────────────────────────────────────────────────
# Private key of the wallet that funds generated accounts with CELO
FUNDER_PRIVATE_KEY=0xYOUR_FUNDER_PRIVATE_KEY_HERE

# Optional: override the default Celo RPC (defaults to https://forno.celo.org)
CELO_RPC_URL=https://forno.celo.org

# Optional: override the Vibeplay contract address (defaults to mainnet deployment)
