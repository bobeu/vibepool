generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}
model UserProfile {
  id            String    @id @default(cuid()) @db.Uuid
  wallet        String    @unique @db.VarChar(42)
  username      String?   @db.VarChar(64)
  avatar        String?   @db.Text
  xp            Int       @default(0)
  points        Int       @default(0)
  spins         Int       @default(0)
  level         Int       @default(0)
  currentRank   Int?
  lastLogin     DateTime? @db.Timestamp
  totalActivity Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now()) @db.Timestamp
  updatedAt     DateTime  @updatedAt @db.Timestamp

  predictions        Prediction[]
  userMissions       UserMission[]
  spinLedgers        SpinLedger[]
  rewardLedgers      RewardLedger[]
  activities         Activity[]
  leaderboardSnapshots LeaderboardSnapshot[]
  notifications      Notification[]
  sessions           Session[]
  pendingRewards     PendingReward[]
  spinHistories      SpinHistory[]
  rewardClaims       RewardClaim[]
  playerStats        PlayerStatistic[]
  notificationPrefs  NotificationPreference[]
  playerIdentity     PlayerIdentity?
  userAchievements   UserAchievement[]
  progressSnapshots  ProgressSnapshot[]
  unlockAnimations   UnlockAnimation[]

  friendRequestsSent     FriendRequest[] @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestReceiver")
  friendsAsUser          Friendship[]    @relation("FriendshipUser")
  friendsAsFriend        Friendship[]    @relation("FriendshipFriend")
  referralsMade          Referral[]       @relation("ReferralReferrer")
  referralsReceived      Referral[]       @relation("ReferralReferred")
  inviteCodes            InviteCode[]
  communityPosts         CommunityPost[]
  feedItemsOwned         FeedItem[] @relation("FeedItemOwner")
  feedItemsActed         FeedItem[] @relation("FeedItemActor")
  presences              Presence[]
  presenceSessions       PresenceSession[]
  relationshipsInitiated PlayerRelationship[] @relation("RelationshipInitiator")
  relationshipsTargeted  PlayerRelationship[] @relation("RelationshipTarget")
  socialSettings         SocialSettings?
  arenaRatings           ArenaRating[]
  arenaQueueEntries      ArenaQueue[]
  matchParticipants      MatchParticipant[]
  arenaInvitationsSent   ArenaInvitation[] @relation("ArenaInvitationSender")
  arenaInvitationsRecv   ArenaInvitation[] @relation("ArenaInvitationReceiver")
  arenaPresence          ArenaPresence?
  arenaSeasonStats       ArenaSeasonStatistic[]
  seasonProgress         SeasonProgress[]
  bannerDismissals       BannerDismissal[]
  campaignTargets        CampaignTarget[]

  @@index([wallet])
  @@index([status])
}

model Tournament {
  id            String          @id @default(cuid()) @db.Uuid
  name          String          @db.VarChar(120)
  startTime     DateTime        @db.Timestamp
  endTime       DateTime        @db.Timestamp
  status        TournamentStatus @default(UPCOMING)
  rewardPool    Int
  asset         String          @db.VarChar(42)
  maxPlayers    Int
  currentPlayers Int           @default(0)
  seasonNumber  Int
  dailyNumber   Int
  actualValue   Int?
  createdAt     DateTime        @default(now()) @db.Timestamp
  updatedAt     DateTime        @updatedAt @db.Timestamp

  predictions        Prediction[]
  leaderboardSnapshots LeaderboardSnapshot[]
  executions         GameExecution[]
  pendingRewards     PendingReward[]

  @@index([status, startTime])
  @@index([seasonNumber, dailyNumber])
}

model Prediction {
  id            String         @id @default(cuid()) @db.Uuid
  tournamentId  String         @db.Uuid
  userId        String         @db.Uuid
  predictionValue Int
  submittedValue Int?
  actualValue   Int?
  accuracy      Float?
  rankPoints    Int            @default(0)
  xpAwarded     Int            @default(0)
  status        PredictionStatus @default(PENDING)
  submittedAt   DateTime?      @db.Timestamp
  createdAt     DateTime       @default(now()) @db.Timestamp
  updatedAt     DateTime       @updatedAt @db.Timestamp

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, userId])
  @@index([userId, status])
  @@unique([tournamentId, userId])
}

model DailyMission {
  id          String       @id @default(cuid()) @db.Uuid
  title       String       @db.VarChar(120)
  description String       @db.Text
  xpReward    Int
  pointReward Int
  spinReward  Int
  missionType String       @db.VarChar(64)
  category    MissionCategory @default(DAILY)
  targetValue Int
  config      Json?
  status      MissionStatus @default(ACTIVE)
  startDate   DateTime     @db.Timestamp
  endDate     DateTime     @db.Timestamp
  createdAt   DateTime     @default(now()) @db.Timestamp
  updatedAt   DateTime     @updatedAt @db.Timestamp

  userMissions UserMission[]
  rewards MissionReward[]

  @@index([category, status])
  @@index([status, startDate])
}

model UserMission {
  id           String    @id @default(cuid()) @db.Uuid
  userId       String    @db.Uuid
  missionId    String    @db.Uuid
  category     MissionCategory @default(DAILY)
  currentValue Int       @default(0)
  targetValue  Int
  completed    Boolean   @default(false)
  completedAt  DateTime? @db.Timestamp
  claimable    Boolean   @default(false)
  claimed      Boolean   @default(false)
  claimedAt    DateTime? @db.Timestamp
  rewardClaimed Boolean @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamp
  updatedAt    DateTime  @updatedAt @db.Timestamp

  user    UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission DailyMission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([userId, completed])
}

model MissionReward {
  id        String       @id @default(cuid()) @db.Uuid
  missionId String       @db.Uuid
  rewardType RewardAssetType
  amount    Int
  createdAt DateTime     @default(now()) @db.Timestamp

  mission DailyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model SpinLedger {
  id              String     @id @default(cuid()) @db.Uuid
  userId          String     @db.Uuid
  spinType        SpinType
  amount          Int
  reason          String?
  transactionHash String?    @db.VarChar(66)
  createdAt       DateTime   @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RewardLedger {
  id               String     @id @default(cuid()) @db.Uuid
  userId           String     @db.Uuid
  reward           String     @db.VarChar(120)
  asset            String     @db.VarChar(42)
  amount           Int
  reason           String?
  transactionHash  String?    @db.VarChar(66)
  treasuryRequestId String?   @db.VarChar(66)
  createdAt        DateTime   @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([treasuryRequestId])
}

model Activity {
  id        String       @id @default(cuid()) @db.Uuid
  userId    String       @db.Uuid
  type      ActivityType
  metadata  Json?
  createdAt DateTime     @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model LeaderboardSnapshot {
  id               String    @id @default(cuid()) @db.Uuid
  tournamentId     String?   @db.Uuid
  userId           String    @db.Uuid
  rank             Int
  xp               Int
  points           Int
  predictionAccuracy Float?
  snapshotTime     DateTime  @db.Timestamp
  createdAt        DateTime  @default(now()) @db.Timestamp

  user       UserProfile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([tournamentId, snapshotTime])
  @@index([userId, snapshotTime])
}

model Notification {
  id        String          @id @default(cuid()) @db.Uuid
  userId    String          @db.Uuid
  type      NotificationType
  title     String          @db.VarChar(120)
  body      String          @db.Text
  read      Boolean         @default(false)
  readAt    DateTime?       @db.Timestamp
  priority  NotificationPriority @default(NORMAL)
  expiresAt DateTime?       @db.Timestamp
  scheduledAt DateTime?     @db.Timestamp
  recurring  Boolean        @default(false)
  channel   NotificationChannel @default(IN_APP)
  deliveryStatus String?    @db.VarChar(32)
  createdAt DateTime        @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, priority, createdAt])
  @@index([scheduledAt])
}

model Settings {
  id        String   @id @default(cuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @db.Timestamp
}

model GameExecution {
  id               String        @id @default(cuid()) @db.Uuid
  tournamentId     String        @db.Uuid
  engineVersion    String        @db.VarChar(64)
  status           GameExecStatus @default(PENDING)
  startedAt        DateTime      @default(now()) @db.Timestamp
  completedAt      DateTime?     @db.Timestamp
  errors           Json?
  metadata         Json?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, status])
}

model PendingReward {
  id               String        @id @default(cuid()) @db.Uuid
  userId           String        @db.Uuid
  tournamentId     String?       @db.Uuid
  predictionId     String?       @db.Uuid
  reward           String        @db.VarChar(120)
  asset            String        @db.VarChar(42)
  amount           Int
  reason           String?
  treasuryRequestId String?      @db.VarChar(66)
  status           RewardStatus  @default(PENDING)
  transactionHash  String?       @db.VarChar(66)
  txAttempts       Int           @default(0)
  lastError        String?       @db.Text
  createdAt        DateTime      @default(now()) @db.Timestamp
  updatedAt        DateTime      @updatedAt @db.Timestamp

  user       UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([treasuryRequestId])
}

model AuditLog {
  id            String   @id @default(cuid()) @db.Uuid
  actor         String?  @db.VarChar(42)
  action        String   @db.VarChar(120)
  entity        String?  @db.VarChar(120)
  entityId      String?  @db.VarChar(42)
  eventId       String?  @db.VarChar(42)
  sessionId     String?  @db.VarChar(42)
  correlationId String?  @db.VarChar(64)
  metadata      Json?
  recordHash    String?  @db.VarChar(64)
  previousHash  String?  @db.VarChar(64)
  createdAt     DateTime @default(now()) @db.Timestamp

  @@index([action, createdAt])
  @@index([entity, entityId])
  @@index([eventId])
  @@index([correlationId])
  @@index([recordHash])
}

model Session {
  id           String    @id @default(cuid()) @db.Uuid
  userId       String    @db.Uuid
  wallet       String    @db.VarChar(42)
  refreshToken String    @unique @db.VarChar(128)
  userAgent    String?   @db.VarChar(255)
  ip           String?   @db.VarChar(45)
  expiresAt    DateTime  @db.Timestamp
  revoked      Boolean   @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamp
  updatedAt    DateTime  @updatedAt @db.Timestamp

  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenRecord RefreshToken?

  @@index([userId, revoked, expiresAt])
}

model RefreshToken {
  id           String   @id @default(cuid()) @db.Uuid
  sessionId    String   @unique @db.Uuid
  token        String   @unique @db.VarChar(128)
  expiresAt    DateTime @db.Timestamp
  revoked      Boolean  @default(false)
  replacedBy   String?  @db.VarChar(128)
  createdAt    DateTime @default(now()) @db.Timestamp

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, revoked, expiresAt])
}

model PlayerStatistic {
  id        String       @id @default(cuid()) @db.Uuid
  userId    String       @db.Uuid
  type      StatisticType
  value     Int          @default(0)
  metadata  Json?
  createdAt DateTime     @default(now()) @db.Timestamp
  updatedAt DateTime     @updatedAt @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, type])
}

model NotificationPreference {
  id        String   @id @default(cuid()) @db.Uuid
  userId    String   @db.Uuid
  eventType String   @db.VarChar(64)
  enabled   Boolean  @default(true)
  channels  Json?
  createdAt DateTime @default(now()) @db.Timestamp
  updatedAt DateTime @updatedAt @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
}

model Achievement {
  id          String            @id @default(cuid()) @db.Uuid
  slug        String            @unique @db.VarChar(120)
  title       String            @db.VarChar(120)
  description String            @db.Text
  category    AchievementCategory @default(DAILY)
  rarity      AchievementRarity @default(COMMON)
  xpReward    Int               @default(0)
  pointsReward Int              @default(0)
  icon        String?           @db.VarChar(120)
  criteria    Json?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @db.Timestamp
  updatedAt   DateTime          @updatedAt @db.Timestamp

  rules       AchievementRule[]
  userAchievements UserAchievement[]
  ruleGroups AchievementRuleGroup[]
}

model AchievementRule {
  id            String   @id @default(cuid()) @db.Uuid
  achievementId String   @db.Uuid
  groupId       String?  @db.Uuid
  statType      StatisticType
  operator      String   @db.VarChar(16)
  targetValue   Int
  windowDays    Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamp

  achievement Achievement        @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  group      AchievementRuleGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([achievementId])
  @@index([statType])
}

model AchievementRuleGroup {
  id            String   @id @default(cuid()) @db.Uuid
  achievementId String   @db.Uuid
  logic         RuleLogic @default(AND)
  createdAt     DateTime @default(now()) @db.Timestamp

  achievement Achievement     @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  rules       AchievementRule[]

  @@index([achievementId])
}

model UserAchievement {
  id            String   @id @default(cuid()) @db.Uuid
  userId        String   @db.Uuid
  achievementId String   @db.Uuid
  progress      Int      @default(0)
  target        Int      @default(1)
  unlocked      Boolean  @default(false)
  unlockedAt    DateTime? @db.Timestamp
  notified      Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamp
  updatedAt     DateTime @updatedAt @db.Timestamp

  user        UserProfile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlocked])
}

model Badge {
  id        String       @id @default(cuid()) @db.Uuid
  slug      String       @unique @db.VarChar(120)
  name      String       @db.VarChar(120)
  tier      BadgeTier     @default(BRONZE)
  icon      String?      @db.VarChar(120)
  createdAt DateTime     @default(now()) @db.Timestamp
  updatedAt DateTime     @updatedAt @db.Timestamp
}

model Title {
  id          String       @id @default(cuid()) @db.Uuid
  slug        String       @unique @db.VarChar(120)
  name        String       @db.VarChar(120)
  rarity      TitleRarity   @default(COMMON)
  requirement String?      @db.Text
  createdAt   DateTime      @default(now()) @db.Timestamp
  updatedAt   DateTime      @updatedAt @db.Timestamp
}

model AvatarFrame {
  id        String   @id @default(cuid()) @db.Uuid
  slug      String   @unique @db.VarChar(120)
  name      String   @db.VarChar(120)
  rarity    TitleRarity @default(COMMON)
  cssClass  String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp
  updatedAt DateTime @updatedAt @db.Timestamp
}

model PlayerIdentity {
  id            String   @id @default(cuid()) @db.Uuid
  userId        String   @unique @db.Uuid
  displayName   String?  @db.VarChar(64)
  selectedTitle String?  @db.VarChar(120)
  selectedBadge String?  @db.VarChar(120)
  selectedFrame String?  @db.VarChar(120)
  theme         String?  @db.VarChar(32)
  schemaVersion Int      @default(1)
  updatedAt     DateTime @updatedAt @db.Timestamp

  user     UserProfile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions PlayerIdentityVersion[]
}

model PlayerIdentityVersion {
  id            String   @id @default(cuid()) @db.Uuid
  identityId    String   @db.Uuid
  userId        String   @db.Uuid
  version       Int
  displayName   String?  @db.VarChar(64)
  selectedTitle String?  @db.VarChar(120)
  selectedBadge String?  @db.VarChar(120)
  selectedFrame String?  @db.VarChar(120)
  theme         String?  @db.VarChar(32)
  snapshot      Json?
  createdAt     DateTime @default(now()) @db.Timestamp

  identity PlayerIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([userId, version])
}

model ProgressSnapshot {
  id            String   @id @default(cuid()) @db.Uuid
  userId        String   @db.Uuid
  snapshotType  String   @db.VarChar(64)
  level         Int      @default(0)
  xp            Int      @default(0)
  points        Int      @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotType, createdAt])
}

model UnlockAnimation {
  id            String   @id @default(cuid()) @db.Uuid
  userId        String   @db.Uuid
  type          String   @db.VarChar(64)
  referenceId   String?  @db.VarChar(42)
  payload       Json?
  viewed        Boolean  @default(false)
  priority      String   @db.VarChar(16) @default("NORMAL")
  interrupt     Boolean  @default(false)
  position      Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, viewed])
  @@index([userId, priority])
}

model RateLimitEntry {
  id          String    @id @default(cuid()) @db.Uuid
  identifier  String    @db.VarChar(120)
  endpoint    String    @db.VarChar(120)
  count       Int       @default(1)
  windowStart DateTime  @db.Timestamp
  expiresAt   DateTime  @db.Timestamp
  createdAt   DateTime  @default(now()) @db.Timestamp
  updatedAt   DateTime  @updatedAt @db.Timestamp

  @@index([identifier, endpoint, createdAt])
  @@index([expiresAt])
}

model DomainEvent {
  id            String   @id @default(cuid()) @db.Uuid
  aggregateId   String   @db.VarChar(42)
  aggregateType String   @db.VarChar(64)
  eventType     String   @db.VarChar(120)
  payload       Json?
  occurredAt    DateTime @default(now()) @db.Timestamp
  version       Int      @default(1)
  processed     Boolean  @default(false)

  @@index([aggregateId, occurredAt])
  @@index([eventType, processed])
  @@index([occurredAt])
}

model SpinReward {
  id        String     @id @default(cuid()) @db.Uuid
  name      String     @db.VarChar(120)
  asset     String     @db.VarChar(42)
  amount    Int
  weight    Int        @default(1)
  rarity    String     @db.VarChar(32)
  config    Json?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @db.Timestamp
  updatedAt DateTime   @updatedAt @db.Timestamp

  spinHistories SpinHistory[]
}

model SpinHistory {
  id              String     @id @default(cuid()) @db.Uuid
  userId          String     @db.Uuid
  spinRewardId    String?   @db.Uuid
  reward          String     @db.VarChar(120)
  asset           String     @db.VarChar(42)
  amount          Int
  reason          String?
  transactionHash String?    @db.VarChar(66)
  seed            String?    @db.VarChar(64)
  randomNumber    String?    @db.VarChar(64)
  weightUsed      Int?
  createdAt       DateTime   @default(now()) @db.Timestamp

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  spinReward SpinReward? @relation(fields: [spinRewardId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model RewardClaim {
  id               String    @id @default(cuid()) @db.Uuid
  userId           String    @db.Uuid
  reward           String    @db.VarChar(120)
  asset            String    @db.VarChar(42)
  amount           Int
  reason           String?
  transactionHash  String?   @db.VarChar(66)
  status           RewardStatus @default(PENDING)
  createdAt        DateTime  @default(now()) @db.Timestamp

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RewardQueue {
  id               String    @id @default(cuid()) @db.Uuid
  userId           String    @db.Uuid
  reward           String    @db.VarChar(120)
  asset            String    @db.VarChar(42)
  amount           Int
  source           RewardSource
  reason           String?
  status           RewardStatus @default(PENDING)
  priority         RewardPriority @default(NORMAL)
  attempts         Int       @default(0)
  maxAttempts      Int       @default(3)
  lastError        String?   @db.Text
  deadLetter       Boolean   @default(false)
  scheduledAt      DateTime?
  processedAt      DateTime?
  createdAt        DateTime  @default(now()) @db.Timestamp
  updatedAt        DateTime  @updatedAt @db.Timestamp

  @@index([userId, status])
  @@index([status, scheduledAt])
  @@index([status, priority])
}

model RewardSourceCatalog {
  id        String   @id @default(cuid()) @db.Uuid
  name      String   @db.VarChar(64)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp

  @@unique([name])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  SHADOW_BANNED
}

enum TournamentStatus {
  UPCOMING
  OPEN
  LOCKED
  EVALUATING
  COMPLETED
  ARCHIVED
}

enum PredictionStatus {
  PENDING
  EVALUATED
  REWARDED
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum ActivityType {
  LOGIN
  PREDICTION
  MISSION
  SPIN
  REWARD
  SOCIAL
  TOURNAMENT
}

enum NotificationType {
  INFO
  REWARD
  SYSTEM
  ALERT
}

enum SpinType {
  DAILY
  REWARD
  PURCHASE
  EVENT
}

enum MissionCategory {
  DAILY
  WEEKLY
  MILESTONE
  HIDDEN
  SEASONAL
}

enum RewardAssetType {
  XP
  POINTS
  SPINS
  CELO
  USDT
  USDM
}

enum StatisticType {
  PREDICTIONS_SUBMITTED
  PREDICTIONS_WON
  PREDICTION_ACCURACY
  XP_EARNED
  POINTS_EARNED
  REWARDS_EARNED
  SPINS_EARNED
  SPINS_USED
  LOGIN_DAYS
  CURRENT_STREAK
  LONGEST_STREAK
  MISSION_COMPLETION_PERCENTAGE
  TOURNAMENT_WINS
  LEADERBOARD_FINISHES
  ARENA_MATCHES
  ARENA_WINS
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  COMPLETED
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum GameExecStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum RewardStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum RewardPriority {
